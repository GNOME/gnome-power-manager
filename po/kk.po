#. TRANSLATORS: the program name
#: data/org.gnome.PowerStats.desktop.in:2 src/gpm-statistics.c:983
#: src/gpm-statistics.c:1604 src/gpm-statistics.ui:5
msgid "Power Statistics"
msgstr "Қуат статистикасы"

#: data/org.gnome.PowerStats.desktop.in:3
#: data/appdata/org.gnome.PowerStats.metainfo.xml.in:8
msgid "Observe power management"
msgstr "Қуатты басқаруды бақылау"

#. Translators: Search terms to find this application. Do NOT translate or
#. localize the semicolons! The list MUST also end with a semicolon!
#: data/org.gnome.PowerStats.desktop.in:5
msgid "battery;consumption;charge;"
msgstr "батарея;тұтыну;заряд;"

#: data/appdata/org.gnome.PowerStats.metainfo.xml.in:7
msgid "GNOME Power Statistics"
msgstr "Gnome қуат статистикасы"

#: data/appdata/org.gnome.PowerStats.metainfo.xml.in:10
msgid ""
"Power Statistics can show historical and current battery information and "
"programs waking up that use power."
msgstr ""
"Қуат статистикасы батарея туралы тарихи және ағымдағы ақпаратты, сондай-ақ "
"қуатты тұтынатын бағдарламаларды көрсете алады."

#: data/appdata/org.gnome.PowerStats.metainfo.xml.in:14
msgid ""
"You probably only need to install this application if you are having "
"problems with your laptop battery, or are trying to work out what programs "
"are using significant amounts of power."
msgstr ""
"Бұл бағдарламалық қамтаны ноутбук батареясында қиындықтар туындағанда "
"немесе қай бағдарламалар көп қуат тұтынатынын анықтағыңыз келгенде ғана "
"орнату қажет болуы мүмкін."

#: data/org.gnome.power-manager.gschema.xml:5
msgid "Whether we should show the history data points"
msgstr "Тарих деректерінің нүктелерін көрсету керек пе"

#: data/org.gnome.power-manager.gschema.xml:6
msgid ""
"Whether we should show the history data points in the statistics window."
msgstr ""
"Статистика терезесінде тарих деректерінің нүктелерін көрсету керек пе."

#: data/org.gnome.power-manager.gschema.xml:10
msgid "Whether we should smooth the history data"
msgstr "Тарих деректерін тегістеу керек пе"

#: data/org.gnome.power-manager.gschema.xml:11
msgid "Whether we should smooth the history data in the graph."
msgstr "Графиктегі тарих деректерін тегістеу керек пе."

#: data/org.gnome.power-manager.gschema.xml:15
msgid "The default graph type to show for history"
msgstr "Тарих үшін көрсетілетін графиктің әдепкі түрі"

#: data/org.gnome.power-manager.gschema.xml:16
msgid "The default graph type to show in the history window."
msgstr "Тарих терезесінде көрсетілетін графиктің әдепкі түрі."

#: data/org.gnome.power-manager.gschema.xml:20
msgid "The maximum time displayed for history"
msgstr "Тарих үшін көрсетілетін максималды уақыт"

#: data/org.gnome.power-manager.gschema.xml:21
msgid ""
"The maximum duration of time displayed on the x-axis of the history graph."
msgstr "Тарих графигінің x-осінде көрсетілетін уақыттың максималды ұзақтығы."

#: data/org.gnome.power-manager.gschema.xml:25
msgid "Whether we should show the stats data points"
msgstr "Статистика деректерінің нүктелерін көрсету керек пе"

#: data/org.gnome.power-manager.gschema.xml:26
msgid "Whether we should show the stats data points in the statistics window."
msgstr ""
"Статистика терезесінде статистика деректерінің нүктелерін көрсету керек пе."

#: data/org.gnome.power-manager.gschema.xml:30
msgid "Whether we should smooth the stats data"
msgstr "Статистика деректерін тегістеу керек пе"

#: data/org.gnome.power-manager.gschema.xml:31
msgid "Whether we should smooth the stats data in the graph."
msgstr "Графиктегі статистика деректерін тегістеу керек пе."

#: data/org.gnome.power-manager.gschema.xml:35
msgid "The default graph type to show for stats"
msgstr "Статистика үшін көрсетілетін графиктің әдепкі түрі"

#: data/org.gnome.power-manager.gschema.xml:36
msgid "The default graph type to show in the stats window."
msgstr "Статистика терезесінде көрсетілетін графиктің әдепкі түрі."

#: data/org.gnome.power-manager.gschema.xml:40
msgid "The index of the page number to show by default"
msgstr "Әдепкі бойынша көрсетілетін бет нөмірінің нұсқағышы"

#: data/org.gnome.power-manager.gschema.xml:41
msgid ""
"The index of the page number to show by default which is used to return "
"focus to the correct page."
msgstr ""
"Фокусты дұрыс бетке қайтару үшін қолданылатын, әдепкі бойынша көрсетілетін "
"бет нөмірінің нұсқағышы."

#: data/org.gnome.power-manager.gschema.xml:45
msgid "The ID of the last device selected"
msgstr "Соңғы таңдалған құрылғының ID-і"

#: data/org.gnome.power-manager.gschema.xml:46
msgid ""
"The identifier of the last device which is used to return focus to the "
"correct device."
msgstr ""
"Фокусты дұрыс құрылғыға қайтару үшін қолданылатын соңғы құрылғының "
"идентификаторы."

